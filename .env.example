# Database
DATABASE_URL=postgresql://kyomiru:kyomiru@localhost:5432/kyomiru

# Redis
REDIS_URL=redis://localhost:6379

# App secrets (generate with: openssl rand -base64 32)
APP_SECRET_KEY=REPLACE_ME_32_BYTE_BASE64
SESSION_SECRET=REPLACE_ME_RANDOM_STRING

# Google OAuth (https://console.cloud.google.com)
# Required unless MOCK_GOOGLE_AUTH_USER is set below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:3000/api/auth/callback

# DEV ONLY — bypass Google OIDC and sign in as the given email.
# Hitting /api/auth/google immediately creates a session for this user.
# Leave empty in production.
MOCK_GOOGLE_AUTH_USER=

# Access control — when true, only pre-approved emails may sign in.
# Default: false (everyone who can authenticate via Google gets access).
DISABLE_AUTO_SIGNUP=false

# Glob pattern for auto-approving emails without an explicit approved_emails row.
# * matches any characters. Examples:
#   *@company.com        (anyone at company.com)
#   *@*.company.com      (anyone at any subdomain)
# Leave empty to rely solely on the approved_emails table.
# Only takes effect when DISABLE_AUTO_SIGNUP=true.
AUTO_SIGNUP_EMAIL_PATTERN=

# Origins
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3000

# Third-party APIs
TMDB_API_KEY=

# Comma-separated locale codes for enrichment (show/episode title translations).
# Defaults to en-US,ja-JP,es-ES,fr-FR when not set.
ENRICHMENT_LOCALES=en-US,ja-JP,es-ES,fr-FR

# Worker concurrency — number of parallel jobs each worker type processes.
# Increase on machines with more resources; decrease to reduce external API load.
ENRICHMENT_CONCURRENCY=3
SHOW_REFRESH_CONCURRENCY=3

# Optional
SENTRY_DSN=
PROVIDERS_FIXTURE=false

# API port
PORT=3000
NODE_ENV=development
