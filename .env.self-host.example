# ─── Compose toggles ─────────────────────────────────────────────────────────
# Image version to pull. Use a specific tag (e.g. 0.2.1) to pin, or keep
# "latest" to always pull the newest release.
KYOMIRU_VERSION=latest

# Host port the web container (nginx) is exposed on.
KYOMIRU_PORT=8080

# ─── Secrets (REQUIRED) ──────────────────────────────────────────────────────
# Generate both with: openssl rand -base64 32
APP_SECRET_KEY=REPLACE_ME_32_BYTE_BASE64
SESSION_SECRET=REPLACE_ME_RANDOM_STRING

# ─── Authentication ───────────────────────────────────────────────────────────
# Pick ONE of the two modes below.
#
# The example is preconfigured with MODE 1 (mock auth) so a fresh `docker compose
# up -d` works out of the box. Switch to MODE 2 before exposing to the internet.

# MODE 1 — Zero-config (default; LAN / homelab only)
# Visiting /api/auth/google will instantly create a session for this address —
# no Google Cloud project required.
# WARNING: do not expose this instance to the public internet while this is set.
MOCK_GOOGLE_AUTH_USER=you@example.com

# MODE 2 — Proper Google OAuth
# Comment out MOCK_GOOGLE_AUTH_USER above, then create an OAuth 2.0 Client at
# https://console.cloud.google.com
#   Authorised JavaScript origins:  http://localhost:8080
#   Authorised redirect URIs:       http://localhost:8080/api/auth/callback
# and fill in the three values below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/api/auth/callback

# ─── Origins ─────────────────────────────────────────────────────────────────
# Both values should match the URL your browser uses to reach Kyomiru.
# Behind a reverse proxy, change localhost:8080 to your public domain.
WEB_ORIGIN=http://localhost:8080
API_ORIGIN=http://localhost:8080

# ─── Optional ────────────────────────────────────────────────────────────────
# TMDb API key — enables metadata enrichment for non-anime shows.
# Get one at https://www.themoviedb.org/settings/api (free for personal use).
TMDB_API_KEY=

# Sentry DSN for error reporting.
SENTRY_DSN=
