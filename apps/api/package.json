{
  "name": "@kyomiru/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--conditions=development' tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cron:run": "node dist/cron.js",
    "backfill:enrichment": "node dist/backfillEnrichment.js",
    "backfill:state": "node dist/backfillShowState.js",
    "backfill:translations": "node dist/backfillTranslations.js",
    "approved:add": "node dist/approved.js add",
    "approved:remove": "node dist/approved.js remove",
    "approved:list": "node dist/approved.js list"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/csrf-protection": "^7.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/secure-session": "^8.1.0",
    "@kyomiru/db": "workspace:*",
    "@kyomiru/providers": "workspace:*",
    "@kyomiru/shared": "workspace:*",
    "bullmq": "^5.30.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.1",
    "openid-client": "^6.1.7",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
