{
  "name": "kyomiru",
  "version": "1.7.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e": "turbo run e2e",
    "db:up": "docker compose -f infra/compose/docker-compose.dev.yml up -d",
    "db:down": "docker compose -f infra/compose/docker-compose.dev.yml down",
    "db:migrate": "pnpm --filter @kyomiru/db run migrate",
    "db:generate": "pnpm --filter @kyomiru/db run generate",
    "db:seed": "pnpm --filter @kyomiru/db run seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
