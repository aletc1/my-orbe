{
  "name": "@kyomiru/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./contracts/*": {
      "types": "./src/contracts/*.ts",
      "development": "./src/contracts/*.ts",
      "default": "./dist/contracts/*.js"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "development": "./src/types/*.ts",
      "default": "./dist/types/*.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
