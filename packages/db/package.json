{
  "name": "@kyomiru/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "development": "./src/schema.ts",
      "default": "./dist/schema.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "development": "./src/client.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.1"
  }
}
